# ─────────────────────────────────────────────────────────────────────────────
# Phintra Backend — Environment Configuration (Outlook SMTP Edition)
# Copy this file to .env and fill in your values.
# NEVER commit the real .env file to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=

# ── Security / JWT ────────────────────────────────────────────────────────────
SECRET_KEY=
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ── Frontend URL ──────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:5173

# ── AI / Gemini ───────────────────────────────────────────────────────────────
GEMINI_API_KEY=

# ── Outlook SMTP (Office 365 / Microsoft Exchange) ───────────────────────────
# All campaign and notification emails are sent exclusively via Outlook SMTP.
# Gmail, Yahoo, or other non-Microsoft SMTP providers are NOT supported.
#
# Required settings:
SMTP_HOST=smtp.office365.com
SMTP_PORT=587
SMTP_USE_TLS=true

# SMTP_USER must be a valid Microsoft 365 / Outlook account.
# This can be a corporate address routed through Microsoft Exchange/Office 365
# (e.g. user@yourcompany.com) or a personal Outlook account (user@outlook.com).
SMTP_USER=

# Your Outlook account password or Microsoft 365 app password.
# If your organization uses MFA, generate an App Password in Microsoft account settings.
SMTP_PASSWORD=

# The From address shown to email recipients.
# If different from SMTP_USER, "Send As" permission must be granted in Microsoft 365 Admin.
# Leave blank to use SMTP_USER as the From address.
SMTP_FROM_EMAIL=

# ── Single-Company / Single-Tenant Mode ───────────────────────────────────────
APP_MODE=single_company
COMPANY_NAME= Systech Solutions
COMPANY_DOMAIN= https://systechusa.com/
ALLOWED_ADMIN_EMAIL= sathyasudarv@systechusa.com
ENABLE_PUBLIC_REGISTER=false
ENABLE_MICROSOFT_AUTO_REGISTRATION=false

# ── Microsoft SSO (Optional) ──────────────────────────────────────────────────
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT_ID=common
MICROSOFT_REDIRECT_URI=

# ── Outlook Add-in (Optional) ─────────────────────────────────────────────────
# Shared secret key used by the Outlook Add-in to authenticate report requests.
PHINTRA_ADDON_KEY=
